# Variables defined here will be available to use anywhere in the config with the syntax ${MY_SECRET_TOKEN} 
# but it also must be defined in compse.yaml as an environment variable for the relevant service.
# Note: making changes to this file requires re-running docker compose down && docker compose up -d

pihole_password=YOUR_PIHOLE_PASSWORD

openweathermap_api_key=YOUR_OPENWEATHERMAP_API_KEY